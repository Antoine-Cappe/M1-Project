%Write the value of all electrical components in the .cir file

for i=1:1:size(fem_mesh_p,2)                                        % Loop on the nodes

        fprintf(fie, '%u\t%f\t%f\t%f\n', i, fem_mesh_p(1,i), fem_mesh_p(2,i), fem_mesh_p(3,i));     % Save the coordinates of the mesh in tlm.conf.Name.cor
    
        if size(tlm.result{i},2)~=0                                     % if the array for node i is filled in
            for j=7:7:size(tlm.result{i},2)
            
                if (tlm.result{i}{j}==0)                            % If we are not close to interfaces where special boundary conditions should be setup (excitation electrodes, membranes) on est en  plein dans une zone normale quoi

                    % fprintf(fif, '%u\t%u\t%u\t%u\n', i, tlm.result{i}{j-6}, i ,tlm.result{i}{j-6});
                       
                        
                    if tlm.result{i}{j-4}~=-1
                        fprintf(fid, 'R%u_%u\t%u\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                        tlm.conf.Resistor=tlm.conf.Resistor+1;
                    end
                    if tlm.result{i}{j-3}~=0
                        fprintf(fid, 'C%u_%u\t%u\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                        tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                    end

                  
                elseif (tlm.result{i}{j}==1)    % The segment {i,j} is in the left or right outer electrodes
                    if (size(tlm.geom.boundaryEE{i},2)==1)   % The node i is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%ubis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%ubis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    else                                % the node tlm.result{i}{j-6} is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%ubis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
