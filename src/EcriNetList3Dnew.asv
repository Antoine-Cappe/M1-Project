                    else  % the node tlm.result{i}{j-7} is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%u\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    end
                elseif (tlm.result{i}{j}==11)    % The segment {i,j} is in the cytoplasm(2) and i or j is on the boundary with the nucleus(2)
                    if (size(tlm.geom.boundaryEN{2,i},2)==1) % The node i is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%unbis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%unbis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    else    % the node tlm.result{i}{j-7} is on the boundary              
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%u\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    end
                elseif (tlm.result{i}{j}==12)    % The segment {i,j} is in the nucleus(2) and i or j is on the boundary with the cytoplasme(2)
                    if (size(tlm.geom.boundaryEN{2,i},2)==1) % The node i is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%unter\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%unter\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    else  % the node tlm.result{i}{j-7} is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%u\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    end
                elseif (tlm.result{i}{j}==13)    % The segment {i,j} is in the cytoplasme(2) and i or j is on the boundary with the mitochondria(2)
                    if (size(tlm.geom.boundaryEM{2,i},2)==1) % The node i is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%uobis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%uobis\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    else  % the node tlm.result{i}{j-7} is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%u\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    end
                elseif (tlm.result{i}{j}==14)    % The segment {i,j} is in the mitochondria(2) and i or j is on the boundary with the cytoplasme(2)
                    if (size(tlm.geom.boundaryEM{2,i},2)==1) % The node i is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%uoter\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%uoter\t%u\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    else  % the node tlm.result{i}{j-7} is on the boundary
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'R%u_%u\t%u\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'C%u_%u\t%u\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                    end
                elseif (fem_mesh_t(5,i)==tlm.ind.dom.elec1)||...            % Here we are exactly on the special boundary (solicitation electrode)
                       (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.elec1)||...
                       (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.elec2)||...
                       (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.elec2)
                        % Impedance in the organic medium
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Rter%u_%u\t%uter\t%uter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Cter%u_%u\t%uter\t%uter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the solicitation electrode
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Rbis%u_%u\t%ubis\t%ubis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cbis%u_%u\t%ubis\t%ubis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(1))&&...     % Here we are exactly on the special boundary (cell membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.MilOrga))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(1))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.MilOrga))
                        % Impedance in the organic medium
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Rmter%u_%u\t%umter\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Cmter%u_%u\t%umter\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Rmbis%u_%u\t%umbis\t%umbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cmbis%u_%u\t%umbis\t%umbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(2))&&...     % Here we are exactly on the special boundary (cell membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.MilOrga))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(2))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.MilOrga))
                        % Impedance in the organic medium
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Rmter%u_%u\t%umter\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Cmter%u_%u\t%umter\t%umter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Rmbis%u_%u\t%umbis\t%umbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cmbis%u_%u\t%umbis\t%umbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(1))&&...     % Here we are exactly on the special boundary (Nucleus membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Nucleus(1)))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(1))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Nucleus(1)))    
                        % Impedance in the nucleus
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Rnter%u_%u\t%unter\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Cnter%u_%u\t%unter\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Rnbis%u_%u\t%unbis\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cnbis%u_%u\t%unbis\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(2))&&...     % Here we are exactly on the special boundary (Nucleus membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Nucleus(2)))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(2))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Nucleus(2)))    
                        % Impedance in the nucleus
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Rnter%u_%u\t%unter\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Cnter%u_%u\t%unter\t%unter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Rnbis%u_%u\t%unbis\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cnbis%u_%u\t%unbis\t%unbis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(1))&&...     % Here we are exactly on the special boundary (Mitocho membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Mitocho(1)))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(1))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Mitocho(1)))    
                        % Impedance in the mitochondria
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Roter%u_%u\t%uoter\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Coter%u_%u\t%uoter\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Robis%u_%u\t%uobis\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;  
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cobis%u_%u\t%uobis\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                elseif ((fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Cytoplasme(2))&&...     % Here we are exactly on the special boundary (Mitocho membrane)
                        (fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Mitocho(2)))||...                 
                       ((fem_mesh_t(5,tlm.result{i}{j-6})==tlm.ind.dom.Cytoplasme(2))&&...
                        (fem_mesh_t(5,tlm.result{i}{j-5})==tlm.ind.dom.Mitocho(2)))    
                        % Impedance in the mitochondria
                        if tlm.result{i}{j-4}~=-1
                            fprintf(fid, 'Roter%u_%u\t%uoter\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-4});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-3}~=0
                            fprintf(fid, 'Coter%u_%u\t%uoter\t%uoter\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-3});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                        % Impedance in the Cytoplasme
                        if tlm.result{i}{j-2}~=-1
                            fprintf(fid, 'Robis%u_%u\t%uobis\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-2});
                            tlm.conf.Resistor=tlm.conf.Resistor+1;
                        end
                        if tlm.result{i}{j-1}~=0
                            fprintf(fid, 'Cobis%u_%u\t%uobis\t%uobis\t%17.16e\n',i, tlm.result{i}{j-6}, i, tlm.result{i}{j-6}, tlm.result{i}{j-1});
                            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        end
                end %if (tlm.result{i}{j}==0)
            end %for j=7:7:size(tlm.result{i},2)
        end %if size(tlm.result{i},2)~=0
                            
        % Ajout des éléments parasites
        
        aire=0;
        
        if (size(tlm.geom.boundaryEE{i},1)==1) %parasite of the outer electrode
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j)
                    %if the node is in this boundary triangle
                    % calcul de l'aire du triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Ci%u\t%ubis\t%uter\t%17.16e\n',i,i,i,tlm.var.Ci*aire);
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
            fprintf(fid,'Rw%u\t%uquad\t%uter\tr=''%17.16e/sqrt(FREQ)''\n',i,i,i,tlm.var.Rwf/aire);
            tlm.conf.Resistor=tlm.conf.Resistor+1;            
            fprintf(fid,'Cw%u\t%uquad\t%uter\tc=''%17.16e*sqrt(FREQ)''\n',i,i,i,tlm.var.Cwf*aire);
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
            fprintf(fid,'Rt%u\t%ubis\t%uquad\t%17.16e\n',i,i,i,tlm.var.Rt/aire);
            tlm.conf.Resistor=tlm.conf.Resistor+1;
        
        elseif (size(tlm.geom.boundaryEC{1,i},1)==1)               % cell membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Rm%u\t%umbis\t%umter\t%17.16e\n',i,i,i,((tlm.var.EpaisseurMembrane)/(tlm.var.sig.MembCel(1)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Cm%u\t%umbis\t%umter\t%17.16e\n',i,i,i,((tlm.var.eps.MembCel(1)*aire)/tlm.var.EpaisseurMembrane));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        
        elseif (size(tlm.geom.boundaryEC{2,i},1)==1)               % cell membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Rm%u\t%umbis\t%umter\t%17.16e\n',i,i,i,((tlm.var.EpaisseurMembrane)/(tlm.var.sig.MembCel(2)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Cm%u\t%umbis\t%umter\t%17.16e\n',i,i,i,((tlm.var.eps.MembCel(2)*aire)/tlm.var.EpaisseurMembrane));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        
        elseif (size(tlm.geom.boundaryEN{1,i},1)==1)               % nucleus membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Rn%u\t%unbis\t%unter\t%17.16e\n',i,i,i,(tlm.var.EpaisseurNucleus/(tlm.var.sig.MembNuc(1)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Cn%u\t%unbis\t%unter\t%17.16e\n',i,i,i,((tlm.var.eps.MembNuc(1)*aire)/tlm.var.EpaisseurNucleus));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        
        elseif (size(tlm.geom.boundaryEN{2,i},1)==1)               % nucleus membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Rn%u\t%unbis\t%unter\t%17.16e\n',i,i,i,(tlm.var.EpaisseurNucleus/(tlm.var.sig.MembNuc(2)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Cn%u\t%unbis\t%unter\t%17.16e\n',i,i,i,((tlm.var.eps.MembNuc(2)*aire)/tlm.var.EpaisseurNucleus));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        
        elseif (size(tlm.geom.boundaryEM{1,i},1)==1)               % Mitochondria membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Ro%u\t%uobis\t%uoter\t%17.16e\n',i,i,i,(tlm.var.EpaisseurMitochon/(tlm.var.sig.MembMit(1)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Co%u\t%uobis\t%uoter\t%17.16e\n',i,i,i,((tlm.var.eps.MembMit(1)*aire)/tlm.var.EpaisseurMitochon));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
                        
        elseif (size(tlm.geom.boundaryEM{2,i},1)==1)               % Mitochondria membrane modele
            for j=1:1:size(fem_mesh_e,2) %loop on the triangles at interface
                if i==fem_mesh_e(1,j)||i==fem_mesh_e(2,j)||i==fem_mesh_e(3,j) %if the node is in this boundary triangle
                    d12=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(2,j))).^2)^0.5;
                    d23=sum((fem_mesh_p(:,fem_mesh_e(2,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    d13=sum((fem_mesh_p(:,fem_mesh_e(1,j))-fem_mesh_p(:,fem_mesh_e(3,j))).^2)^0.5;
                    s=0.5*(d12+d23+d13);
                    aire=aire+((s*(s-d12)*(s-d13)*(s-d23))^0.5)/3;
                end  
            end
            
            fprintf(fid,'Ro%u\t%uobis\t%uoter\t%17.16e\n',i,i,i,(tlm.var.EpaisseurMitochon/(tlm.var.sig.MembMit(2)*aire)));
            tlm.conf.Resistor=tlm.conf.Resistor+1;
            fprintf(fid,'Co%u\t%uobis\t%uoter\t%17.16e\n',i,i,i,((tlm.var.eps.MembMit(2)*aire)/tlm.var.EpaisseurMitochon));
            tlm.conf.Capacitor=tlm.conf.Capacitor+1;
            
        end  
        
end %for i

fprintf(fid, '.control\nquit 13\n\n.endc\n.end\n'); 

fprintf(fid, '.END\n');

fclose(fid);

