%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
%                              BIOCAD Program
%                               Release 1.0
%
%   Authors: Vincent Senez
%   
%   Release 1.0 : January 2019
% 
%
%   Routine EcritNetList3D called by Compute.m
%
%   Function: Write the input file (e.g.: xx.sp, xx.cir) for the Spice Simulator 
%
%   Remarks:
%   tlm.result(numeroduptincident)={numduptcible1, numtetra[], R1, C1, R2, C2, h ...}
%   with h=1 : If the segment is in the outer electrodes and one edge is in contact with the organic medium (serum) 
%          2 : If the segment is in the organic medium and one edge is in contact with the outer electrodes 
%          3 : If the segment is in the cytoplasm(1) and one edge is in contact with the organic medium (serum) 
%          4 : If the segment is in the organic medium and one edge is in contact with the cytoplasm(1) 
%          5 : If the segment is in the cytoplasm(1) and one edge is in contact with the nucleus(1) 
%          6 : If the segment is in the nucleus(1) and one edge is in contact with the cytoplasm(1)
%          7 : If the segment is in the cytoplasm(1) and one edge is in contact with the mitochon(1) 
%          8 : If the segment is in the mitochon(1) and one edge is in contact with the cytoplasm(1)
%          9 : If the segment is in the cytoplasm(2) and one edge is in contact with the organic medium
%         10 : If the segment is in the organic medium and one edge is in contact with the cytoplasm(2) 
%         11 : If the segment is in the cytoplasm(2) and one edge is in contact with the nucleus(2) 
%         12 : If the segment is in the nucleus(2) and one edge is in contact with the cytoplasm(2)
%         13 : If the segment is in the cytoplasm(2) and one edge is in contact with the mitochon(2) 
%         14 : If the segment is in the mitochon(2) and one edge is in contact with the cytoplasm(2)
%          Length of the segment : If the segment is at the interface (for parasitics with ST2)
%
%   tlm.geom.boundaryEE{numdupt}=0  or length of the segment if the node is at the interface between the 
%                                   outer electrodes - organic medium (serum) (for the parasitics with ST1)
%   tlm.geom.boundaryEC{numcell,numdupt}=0  or length of the segment if the node is at the interface between the 
%                                   cytoplasm(1) or (2) - organic medium (serum)
%   tlm.geom.boundaryEN{numcell,numdupt}=0  or length of the segment if the node is at the interface between the 
%                                   nucleus(1) or (2) - cytoplasm (1) or (2)
%   tlm.geom.boundaryEM{numcell,numdupt}=0  or length of the segment if the node is at the interface between the 
%                                   mitochondria(1) or (2) - cytoplasm(1) or (2)
%
%   tlm.geom.airvol(numdutrg)= sixth of the volume of the tetrahedron
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

function [tlm,model]=EcriNetList3Dnew(tlm,model)
%function [tlm,fem]=EcriNetList3D(tlm,fem)

%Initialization

global fem_mesh_p;
global fem_mesh_e;
global fem_mesh_t;

tlm.conf.Resistor=0;
tlm.conf.Capacitor=0;

name1=sprintf('%s.cir',tlm.conf.Name);        % Name of the file for the Net List
fid=fopen(name1, 'w');                     % Open the File

name2=sprintf('%s.cor',tlm.conf.Name);        % Name of the file for the coordinates of each node
fie=fopen(name2, 'w');                     % Open the File
% name3=sprintf('%s.tri',tlm.conf.Name);        % Name of the file for the listing of the nodes numbers of each triangle
% fif=fopen(name3, 'w');                     % Open the File

fprintf(fid, '%s.cir\n',tlm.conf.Name);        % Write the first line of the file which is use as a title of the graphical output
fprintf(fid, '********************************************************************************\n');            
fprintf(fid, '*\n');            
fprintf(fid, '*                        Spice Netlist Generated by\n'); 
fprintf(fid, '*\n');            
fprintf(fid, '*                              BIOCAD Program\n');            
fprintf(fid, '*                               Release 1.0\n');            
fprintf(fid, '*\n');            
fprintf(fid, '*   Authors: Vincent Senez\n'); 
fprintf(fid, '*\n');            
fprintf(fid, '*   Release 1.0 : January 2019\n');          
fprintf(fid, '*\n');            
fprintf(fid, '********************************************************************************\n');

% Define the type of analysis

%fprintf(fid,'.CONTROL \n');                         %SPICE3 format allow complex simulation using conditions
%fprintf(fid,'  DESTROY ALL \n'); 
%fprintf(fid, '  AC DEC %f %f %f \n',tlm.var.frequence.step,tlm.var.frequence.min,tlm.var.frequence.max);                        % Wide spectrum analysis, logarithmic variation between 1 and 1e10 Hz, 25 points per decade
%if tlm.conf.points==1       % 2 points measurements 
 %   fprintf(fid, '  WRITE %s.spi vdb(%u,%u)-vdb(%u)-66 vp(%u,%u)-vp(%u) \n', ...
  %          tlm.conf.Name,tlm.ind.pt.elec2,tlm.ind.pt.elec1,tlm.ind.pt.elec1,tlm.ind.pt.elec2,tlm.ind.pt.elec1,tlm.ind.pt.elec2);
%elseif tlm.conf.points==2       % 2 points measurements 
 %   fprintf(fid, '  WRITE %s.spi vdb(%u,%u)-vdb(%u)-66 vp(%u,%u)-vp(%u) \n', ...
  %          tlm.conf.Name,tlm.ind.pt.elec2,tlm.ind.pt.elec1,tlm.ind.pt.elec1,tlm.ind.pt.elec2,tlm.ind.pt.elec1,tlm.ind.pt.elec1);
%elseif tlm.conf.points==4
%%    fprintf(fid, '  WRITE %s.spi db(v(%u)) ph(v(%u)) db(v(%u)) ph(v(%u)) db(v(%u)) ph(v(%u)) \n', ...
    fprintf(fid, '  WRITE %s.spi vdb(%u)-vdb(%u)-66 vp(%u,%u)-vp(%u) \n', ...
            tlm.conf.Name,tlm.ind.pt.mesu2,tlm.ind.pt.mesu1,tlm.ind.pt.elec1,tlm.ind.pt.mesu2,tlm.ind.pt.mesu1,tlm.ind.pt.elec1);
%    fprintf(fid, '  PLOT VDB(%u,%u)-VDB(%u)-100 \n', ...                              % .PLOT generates the .cou file for exploitation of the results by Xelga                             
%            tlm.ind.pt.mesu2, tlm.ind.pt.mesu1, tlm.ind.pt.elec1);                                                 
end
fprintf(fid,'  DESTROY ALL \n'); 
fprintf(fid, '  AC DEC 1 %f %f \n',tlm.var.frequence.min,tlm.var.frequence.min);                        % Wide spectrum analysis, logarithmic variation between 1 and 1e10 Hz, 25 points per decade
fprintf(fid, '  WRITE %s all \n',strcat(tlm.conf.Name, "_", num2str(tlm.var.frequence.min), "Hz.spi_cou"));
fprintf(fid,'  DESTROY ALL \n'); 
ex=round((log10(tlm.var.frequence.max)+log10(tlm.var.frequence.min))/2);
if tlm.var.frequence.max==10
     ex=0;
end
f=5*10^ex;
fprintf(fid, '  AC DEC 1 %f %f \n',f,f);                        % Wide spectrum analysis, logarithmic variation between 1 and 1e10 Hz, 25 points per decade
fprintf(fid, '  WRITE %s.spi_cou all \n',strcat(tlm.conf.Name, "_", num2str(f), "Hz"));
fprintf(fid,'  DESTROY ALL \n'); 
fprintf(fid, '  AC DEC 1 %f %f \n',tlm.var.frequence.max,tlm.var.frequence.max);                        % Wide spectrum analysis, logarithmic variation between 1 and 1e10 Hz, 25 points per decade
fprintf(fid, '  WRITE %s.spi_cou all \n',strcat(tlm.conf.Name, "_", num2str(tlm.var.frequence.max), "Hz"));
fprintf(fid,'.ENDC \n');
                                                                                            
fprintf(fid, 'Vin\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2,tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)

fprintf(fid, 'Rg\t%u\t0\t50e-5\n', tlm.ind.pt.elec1);                % Right outer electrode where there is the ground 

%fprintf(fid, 'Cs1\t%u\t%u\t1e-13\n',tlm.ind.pt.elec2,tlm.ind.pt.mesu2);                 
%fprintf(fid, 'Cs2\t%u\t%u\t1e-13\n',tlm.ind.pt.elec1,tlm.ind.pt.mesu1);
%fprintf(fid, 'Ram\t%u\t%u\t1e6\n',tlm.ind.pt.mesu1,tlm.ind.pt.mesu2);
%fprintf(fid, 'Ca1\t%u\t0\t1e-10\n',tlm.ind.pt.mesu2);                 
%fprintf(fid, 'Ca2\t%u\t0\t1e-10\n',tlm.ind.pt.mesu1);

if tlm.conf.points==1
    fprintf(fid, 'Vin1a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
    fprintf(fid, 'Vin1b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
    fprintf(fid, 'Vin1c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
    fprintf(fid, 'Vin1d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
    fprintf(fid, 'Vin1e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
    fprintf(fid, 'Vin1f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
elseif (tlm.conf.points==2 || tlm.conf.points==4)
     if abs(tlm.var.EpaisseurChambre-tlm.var.EpaisseurElectrode)>1e-10 
        fprintf(fid, 'Vin1a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin1g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(1),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin2g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(2),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin3g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(3),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin4g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(4),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin5g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(5),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin6g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(6),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7a\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supa(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7b\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supb(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7c\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supc(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7d\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supd(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7e\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supe(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7f\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supf(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)
        fprintf(fid, 'Vin7g\t%u\t0\tDC 0 AC %f\n', tlm.ind.pt.elec2supg(7),tlm.var.v0);        % Left outer electrode where there is the solicitation (here tlm.var.v0)

    end
end
if tlm.conf.points==1
    fprintf(fid, 'Rg1a\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supa(1));                % Right outer electrode where there is the ground
    fprintf(fid, 'Rg1b\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supb(1));                % Right outer electrode where there is the ground 
    fprintf(fid, 'Rg1c\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supc(1));                % Right outer electrode where there is the ground 
    fprintf(fid, 'Rg1d\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supd(1));                % Right outer electrode where there is the ground 
    fprintf(fid, 'Rg1e\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supe(1));                % Right outer electrode where there is the ground 
    fprintf(fid, 'Rg1f\t%u\t0\t7e-5\n',tlm.ind.pt.elec1supf(1));                % Right outer electrode where there is the ground
elseif (tlm.conf.points==2 || tlm.conf.points==4)
    if abs(tlm.var.EpaisseurChambre-tlm.var.EpaisseurElectrode)>1e-10 
        fprintf(fid, 'Rg1a\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supa(1));                % Right outer electrode where there is the ground
        fprintf(fid, 'Rg1b\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supb(1));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg1c\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supc(1));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg1d\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supd(1));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg1e\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supe(1));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg1f\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supf(1));                % Right outer electrode where there is the ground
        fprintf(fid, 'Rg1g\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supg(1));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2a\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supa(2));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2b\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supb(2));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2c\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supc(2));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2d\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supd(2));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2e\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supe(2));                % Right outer electrode where there is the ground 
        fprintf(fid, 'Rg2f\t%u\t0\t50e-5\n',tlm.ind.pt.elec1supf(2));                % Right outer electrode where there is the ground
